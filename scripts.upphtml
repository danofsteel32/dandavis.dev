  <h1>Scripts</h1>
  <p>Just a collection of short scripts I have found useful.</p>
  <ul>
#!
for script in scripts/*; do
  script_name="$(basename ${script})" 
#!
    <li><a href=${script}>${script_name}</a></li>
#!
done
#!
  </ul>
